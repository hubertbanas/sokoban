# -----------------------------------------------------------------------------
# Sokoban ignore rules
# Stack: Vite + React + TypeScript + Electron + Capacitor/Android
# -----------------------------------------------------------------------------
# Goals:
# - Keep generated build artifacts out of source control
# - Prevent accidental commits of local credentials/secrets
# - Ignore machine-specific editor/OS metadata

# Node/Yarn dependencies and package-manager state
/node_modules/
/.pnp
.pnp.js
/.npm/
/.pnpm-store/
/.yarn/*
!/.yarn/patches/
!/.yarn/plugins/
!/.yarn/releases/
!/.yarn/sdks/
!/.yarn/versions/

# Build outputs and tool caches (web, tests, desktop packaging)
/dist/
/dist-desktop/
/build/
/coverage/
/local-releases/
/build-logs/
/.flatpak-builder/
.vite/
*.tsbuildinfo
.eslintcache

# Android/Capacitor generated outputs
# (Some are also handled in android/.gitignore; duplicated here for root safety.)
/android/.gradle/
/android/build/
/android/app/build/
/android/capacitor-cordova-android-plugins/
/android/app/src/main/assets/public/
/android/app/src/main/assets/capacitor.config.json
/android/app/src/main/assets/capacitor.plugins.json
/android/app/src/main/res/xml/config.xml

# Environment files and local secrets.
# Keep examples committed (e.g. .env.example, .env.production.example).
.env
.env.*
!.env.example
!.env.*.example
/.secrets/

# Android signing material and machine-local Gradle config
/android/local.properties
/android/app/keystore.jks
*.jks
*.keystore
keystore-base64.txt
.env.android-release

# Logs and runtime traces
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local scratch notes
notes.md

# Editor/IDE metadata
.vscode/
.idea/
*.iml
*.swp
*.swo
*~

# OS metadata
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini
