{
  "name": "sokoban",
  "version": "1.15.0-rc.4",
  "private": true,
  "type": "module",
  "main": "electron-main.cjs",
  "description": "A retro Sokoban puzzle game built with Vite, React Hooks, TypeScript, Docker, and GitHub Actions. Forked from ecyrbe/sokoban.",
  "author": "Hubert Banas",
  "contributors": [
    {
      "name": "ecyrbe",
      "url": "https://github.com/ecyrbe/sokoban"
    }
  ],
  "license": "MIT",
  "homepage": "https://hubertbanas.github.io/sokoban/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hubertbanas/sokoban.git"
  },
  "bugs": {
    "url": "https://github.com/hubertbanas/sokoban/issues"
  },
  "keywords": [
    "sokoban",
    "puzzle-game",
    "react",
    "vite",
    "typescript",
    "docker"
  ],
  "dependencies": {
    "@capacitor/core": "^8.2.0",
    "lodash": "4.17.23",
    "react": "19",
    "react-dom": "19"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/lodash": "4.17.24",
    "@types/node": "24",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react": "6",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.0",
    "typescript": "5.9.3",
    "vite": "8",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:desktop": "yarn build && electron-builder --publish never",
    "preview": "vite preview",
    "test": "vitest run --environment jsdom"
  },
  "build": {
    "appId": "com.hubertbanas.sokoban",
    "productName": "Sokoban React",
    "artifactName": "Sokoban.React-${version}.${ext}",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json",
      "public/favicon.ico"
    ],
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": [
        "AppImage",
        "flatpak"
      ],
      "category": "Game"
    }
  }
}