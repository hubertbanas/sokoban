{
  "name": "sokoban",
  "version": "1.17.0-rc.2",
  "private": true,
  "type": "module",
  "main": "electron/electron-main.cjs",
  "description": "A retro Sokoban puzzle game built with Vite, React Hooks, TypeScript, Docker, and GitHub Actions. Forked from ecyrbe/sokoban.",
  "author": {
    "name": "Hubert Banas",
    "email": "hubertbanas@users.noreply.github.com"
  },
  "contributors": [
    {
      "name": "ecyrbe",
      "url": "https://github.com/ecyrbe/sokoban"
    }
  ],
  "license": "MIT",
  "homepage": "https://hubertbanas.github.io/sokoban/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hubertbanas/sokoban.git"
  },
  "bugs": {
    "url": "https://github.com/hubertbanas/sokoban/issues"
  },
  "keywords": [
    "sokoban",
    "puzzle-game",
    "react",
    "vite",
    "typescript",
    "docker"
  ],
  "dependencies": {
    "@capacitor/core": "^8.2.0",
    "lodash": "4.18.1",
    "react": "19",
    "react-dom": "19"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/lodash": "4.17.24",
    "@types/node": "24",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react": "6",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.0",
    "typescript": "5.9.3",
    "vite": "8",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "prepare:desktop-icons": "sh scripts/prepare-icons.sh",
    "prepare:flatpak-metainfo": "sh scripts/prepare-flatpak-metainfo.sh",
    "prebuild:desktop": "yarn prepare:desktop-icons && yarn prepare:flatpak-metainfo",
    "build:desktop": "yarn build && electron-builder --publish never",
    "preview": "vite preview",
    "test": "vitest run --environment jsdom",
    "hooks:install": "sh scripts/install-git-hooks.sh"
  },
  "build": {
    "appId": "com.hubertbanas.sokoban",
    "productName": "Sokoban",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron/electron-main.cjs",
      "package.json",
      "public/icon.ico",
      "public/icon.png",
      "public/favicon.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-${version}-setup-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "flatpak",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "snap",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "pacman",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "extraFiles": [
        {
          "from": "build/flatpak/com.hubertbanas.sokoban.metainfo.xml",
          "to": "usr/share/metainfo/com.hubertbanas.sokoban.metainfo.xml"
        }
      ],
      "category": "Game"
    },
    "flatpak": {
      "branch": "stable",
      "runtimeVersion": "24.08",
      "baseVersion": "24.08",
      "files": [
        [
          "build/flatpak/com.hubertbanas.sokoban.metainfo.xml",
          "/share/metainfo/com.hubertbanas.sokoban.metainfo.xml"
        ]
      ]
    },
    "deb": {
      "packageCategory": "games",
      "synopsis": "A retro Sokoban puzzle game.",
      "description": "Sokoban is a classic puzzle game where you push crates onto target tiles while planning each move carefully to avoid dead ends."
    },
    "rpm": {
      "packageCategory": "Amusements/Games",
      "synopsis": "A retro Sokoban puzzle game.",
      "description": "Sokoban is a classic puzzle game where you push crates onto target tiles while planning each move carefully to avoid dead ends."
    },
    "snap": {
      "confinement": "strict",
      "grade": "stable",
      "summary": "A retro Sokoban puzzle game.",
      "description": "Sokoban is a classic puzzle game where you push crates onto target tiles while planning each move carefully to avoid dead ends."
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.puzzle-games"
    },
    "dmg": {
      "title": "${productName} ${version}",
      "iconSize": 128,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}