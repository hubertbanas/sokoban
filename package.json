{
  "name": "sokoban",
  "version": "1.15.0",
  "private": true,
  "type": "module",
  "main": "electron-main.cjs",
  "description": "A retro Sokoban puzzle game built with Vite, React Hooks, TypeScript, Docker, and GitHub Actions. Forked from ecyrbe/sokoban.",
  "author": {
    "name": "Hubert Banas",
    "email": "hubertbanas@users.noreply.github.com"
  },
  "contributors": [
    {
      "name": "ecyrbe",
      "url": "https://github.com/ecyrbe/sokoban"
    }
  ],
  "license": "MIT",
  "homepage": "https://hubertbanas.github.io/sokoban/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hubertbanas/sokoban.git"
  },
  "bugs": {
    "url": "https://github.com/hubertbanas/sokoban/issues"
  },
  "keywords": [
    "sokoban",
    "puzzle-game",
    "react",
    "vite",
    "typescript",
    "docker"
  ],
  "dependencies": {
    "@capacitor/core": "^8.2.0",
    "lodash": "4.18.1",
    "react": "19",
    "react-dom": "19"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/lodash": "4.17.24",
    "@types/node": "24",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react": "6",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.0",
    "typescript": "5.9.3",
    "vite": "8",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "prebuild:desktop": "bash scripts/prepare-icons.sh",
    "build:desktop": "yarn build && electron-builder --publish never",
    "preview": "vite preview",
    "test": "vitest run --environment jsdom"
  },
  "build": {
    "appId": "com.hubertbanas.sokoban",
    "productName": "Sokoban",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json",
      "public/icon.ico",
      "public/icon.png",
      "public/favicon.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-${version}-setup-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "flatpak",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "snap",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "pacman",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Game"
    },
    "snap": {
      "confinement": "strict",
      "grade": "stable",
      "summary": "A retro Sokoban puzzle game."
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.puzzle-games"
    }
  }
}