<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.hubertbanas.sokoban</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Sokoban</name>
  <summary>A retro Sokoban puzzle game</summary>
  <description>
    <p>
      Sokoban is a classic puzzle game where you push crates onto target tiles while
      planning each move carefully to avoid dead ends.
    </p>
  </description>
  <launchable type="desktop-id">com.hubertbanas.sokoban.desktop</launchable>
  <categories>
    <category>Game</category>
    <category>LogicGame</category>
  </categories>
  <screenshots>
    <screenshot type="default">
      <caption>Sokoban gameplay on desktop</caption>
      <image>https://raw.githubusercontent.com/hubertbanas/sokoban/main/docs/assets/screenshot-gameplay-desktop-light.png</image>
    </screenshot>
  </screenshots>
  <url type="homepage">https://hubertbanas.github.io/sokoban/</url>
  <url type="bugtracker">https://github.com/hubertbanas/sokoban/issues</url>
  <developer_name>Hubert Banas</developer_name>
  <releases>
    <release version="@VERSION@" date="@DATE@"/>
  </releases>
  <content_rating type="oars-1.1"/>
</component>
